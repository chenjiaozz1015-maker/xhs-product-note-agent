APP_ENV=local
APP_NAME=种草机
APP_TITLE=种草机
# 一般不要在 Render / 线上环境配置 APP_VERSION
# 默认直接使用 app/config.py 里的代码版本，升级时不用手动改环境变量
# 只有在极少数需要临时覆盖展示版本时，才单独配置 APP_VERSION
# APP_VERSION=v0.7-4

# 默认线上建议继续使用 rule_based
# 可选：llm_openai_compatible
# openai_compatible 指兼容 OpenAI 风格接口的模型服务，不限定 OpenAI 官方
CONTENT_ENGINE_TYPE=rule_based

LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_CHAT_COMPLETIONS_PATH=/chat/completions
LLM_API_KEY_REF=
LLM_TIMEOUT_SECONDS=15
LLM_MAX_RETRIES=1

# 国产模型平台通常需要配置：
# LLM_BASE_URL=你的模型平台兼容接口地址
# LLM_MODEL=你的模型名称
# LLM_API_KEY=你的平台密钥
# LLM 灰度启用前，请先阅读 docs/llm_rollout_runbook.md
# 启用前建议依次运行：
# python scripts/preflight_llm_rollout.py
# python scripts/check_llm_config.py
# python scripts/smoke_check_llm.py
# python scripts/compare_content_engines.py
# python scripts/batch_evaluate_content.py
# 不要把真实 API Key 或真实服务地址提交到 Git
# 运营脚本总入口：
# python scripts/list_ops_tools.py
# 详细脚本说明：scripts/README.md
# LLM 灰度启用手册：docs/llm_rollout_runbook.md

CONFIG_CENTER_BASE_URL=http://39.106.61.160:28081
CONFIG_CENTER_PROJECT_CODE=zhongcaoji
CONFIG_CENTER_ENV=test
CONFIG_CENTER_RUNTIME_TOKEN_FILE=.config-center/test.runtime-token.json
CONFIG_CENTER_TIMEOUT_SECONDS=10
CONFIG_CENTER_RUNTIME=python
CONFIG_CENTER_LOCAL_WORKSPACE_ROOT=D:\projects\xhs-product-note-agent
CONFIG_CENTER_INVITE_CODE=

POSTER_ENGINE_TYPE=pillow
HOST=0.0.0.0
PORT=8000
SESSION_SECRET=change-this-session-secret
DATABASE_URL=sqlite:///data/zhongcaoji.db


